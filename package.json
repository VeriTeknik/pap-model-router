{
  "name": "pap-model-router",
  "version": "1.0.0",
  "description": "Standalone model router microservice for PAP - routes LLM requests to multiple AI providers",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pap",
    "model-router",
    "llm",
    "openai",
    "anthropic",
    "google",
    "ai"
  ],
  "author": "Plugged.in",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
