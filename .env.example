# Server Configuration
PORT=8080
SERVICE_VERSION=1.0.0
SERVICE_REGION=us-east

# JWT Secret (REQUIRED - must match pluggedin-app)
MODEL_ROUTER_JWT_SECRET=

# Admin Token for pluggedin-app sync (REQUIRED)
# Used by /admin/sync endpoint
MODEL_ROUTER_ADMIN_TOKEN=

# AI Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
